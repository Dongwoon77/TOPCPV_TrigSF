# Name of the final executable program
PROGRAM         = ssb_analysis

# Compiler and linker
CC              = g++
LD              = g++

# ROOT flags
ROOTCFLAGS      = $(shell root-config --cflags)
ROOTLIBS        = $(shell root-config --libs)
ROOTGLIBS       = $(shell root-config --glibs)

# correctionlib flags with env override > cvmfs > pip fallback

CORR_ENV_INCLUDE ?= $(CORRECTION_PATH)
CORR_ENV_LIBPATH ?= $(CORRECTION_LIBPATH)
CORR_CVMFS_INCLUDE := /cvmfs/sft.cern.ch/lcg/releases/correctionlib/2.2.2-13853/x86_64-centos7-gcc11-opt/include
CORR_CVMFS_LIBPATH := /cvmfs/sft.cern.ch/lcg/releases/correctionlib/2.2.2-13853/x86_64-centos7-gcc11-opt/lib

BOOST_INCLUDE := /cvmfs/cms.cern.ch/el9_amd64_gcc12/external/boost/1.80.0-d43be26d8a1ca943bd8818c606afcd2b/include

ifeq ($(wildcard $(CORR_ENV_INCLUDE)/correction.h),)
  ifeq ($(wildcard $(CORR_CVMFS_INCLUDE)/correction.h),)
    # Mac or pip fallback
    CORRCFLAGS = $(shell correction config --cflags)
    CORRLDFLAGS = $(shell correction config --ldflags --rpath)
  else
    CORRCFLAGS = -std=c++17 -I$(CORR_CVMFS_INCLUDE)
    CORRLDFLAGS = -L$(CORR_CVMFS_LIBPATH) -lcorrectionlib -Wl,-rpath,$(CORR_CVMFS_LIBPATH)
  endif
else
  CORRCFLAGS = -std=c++17 -I$(CORR_ENV_INCLUDE)
  CORRLDFLAGS = -L$(CORR_ENV_LIBPATH) -lcorrectionlib -Wl,-rpath,$(CORR_ENV_LIBPATH)
endif

# Compilation and linking flags
#CXXFLAGS = -g -O2 $(ROOTCFLAGS) $(CORRCFLAGS) -std=c++17 
CXXFLAGS = -g -O2 $(ROOTCFLAGS) $(CORRCFLAGS) -I$(BOOST_INCLUDE) -std=c++17 
LDFLAGS         = $(ROOTLIBS) $(CORRLDFLAGS)

# Additional graphical libraries and GenVector
GLIBS           = $(ROOTGLIBS) -L/usr/X11R6/lib -lXext -lGenVector

# List of object files to compile
OBJS = \
    CommonTools.o \
    Analysis.o \
    main_ssb.o \
    TextReader.o \
    utils.o \
    analysisUtils.o \
    KinematicReconstruction_LSroutines.o \
    KinematicReconstruction_MeanSol.o \
    KinematicReconstructionSolution.o \
    KinematicReconstruction.o \
    SSBCorrections.o \
    SSBCPVCalc.o \
    RoccoR.o \
    XYMETCorrection_withUL17andUL18andUL16.o

# Input source and header dependencies
INPUTS = \
    ./interface/Analysis.h ./src/Analysis.cpp main_ssb.cpp \
    ./TextReader/TextReader.hpp ./TextReader/TextReader.cpp \
    ./KinSolv/utils.h ./KinSolv/utils.cc \
    ./KinSolv/analysisUtils.h ./KinSolv/analysisUtils.cc \
    ./KinSolv/KinematicReconstruction_LSroutines.h ./KinSolv/KinematicReconstruction_LSroutines.cc \
    ./KinSolv/KinematicReconstruction_MeanSol.h ./KinSolv/KinematicReconstruction_MeanSol.cc \
    ./KinSolv/KinematicReconstructionSolution.h ./KinSolv/KinematicReconstructionSolution.cc \
    ./KinSolv/KinematicReconstruction.h ./KinSolv/KinematicReconstruction.cc \
    ./interface/SSBCorrections.h ./src/SSBCorrections.cpp \
    ./interface/SSBCPVCalc.h ./src/SSBCPVCalc.cpp \
    ./CorrectionFiles/Rochester/RoccoR.h ./CorrectionFiles/Rochester/RoccoR.cc \
    ./CorrectionFiles/METXY/XYMETCorrection_withUL17andUL18andUL16.h ./CorrectionFiles/METXY/XYMETCorrection_withUL17andUL18andUL16.cpp

# Default rule: build all object files and link them into the final program
all: $(OBJS)
	$(CC) -o $(PROGRAM) -g $(OBJS) $(LDFLAGS)

# Compilation rules for each component
main_ssb.o: main_ssb.cpp $(INPUTS)
	$(CC) $(CXXFLAGS) -c main_ssb.cpp

Analysis.o: ./interface/Analysis.h ./src/Analysis.cpp
	$(CC) $(CXXFLAGS) -c ./src/Analysis.cpp

CommonTools.o: CommonTools.hpp CommonTools.cpp
	$(CC) $(CXXFLAGS) -c CommonTools.cpp

TextReader.o: ./TextReader/TextReader.hpp ./TextReader/TextReader.cpp
	$(CC) $(CXXFLAGS) -c TextReader/TextReader.cpp

utils.o: ./KinSolv/utils.h ./KinSolv/utils.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/utils.cc

analysisUtils.o: ./KinSolv/analysisUtils.h ./KinSolv/analysisUtils.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/analysisUtils.cc

KinematicReconstruction_LSroutines.o: ./KinSolv/KinematicReconstruction_LSroutines.h ./KinSolv/KinematicReconstruction_LSroutines.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/KinematicReconstruction_LSroutines.cc

KinematicReconstruction_MeanSol.o: ./KinSolv/KinematicReconstruction_MeanSol.h ./KinSolv/KinematicReconstruction_MeanSol.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/KinematicReconstruction_MeanSol.cc

KinematicReconstructionSolution.o: ./KinSolv/KinematicReconstructionSolution.h ./KinSolv/KinematicReconstructionSolution.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/KinematicReconstructionSolution.cc

KinematicReconstruction.o: ./KinSolv/KinematicReconstruction.h ./KinSolv/KinematicReconstruction.cc
	$(CC) $(CXXFLAGS) -c ./KinSolv/KinematicReconstruction.cc

# New correctionlib component
SSBCorrections.o: ./interface/SSBCorrections.h ./src/SSBCorrections.cpp
	$(CC) $(CXXFLAGS) -c ./src/SSBCorrections.cpp -o SSBCorrections.o

# SSB CPV Observables Calculator 
SSBCPVCalc.o: ./interface/SSBCPVCalc.h ./src/SSBCPVCalc.cpp
	$(CC) $(CXXFLAGS) -c ./src/SSBCPVCalc.cpp -o SSBCPVCalc.o

# SSB CPV Observables Calculator 
RoccoR.o: ./CorrectionFiles/Rochester/RoccoR.h ./CorrectionFiles/Rochester/RoccoR.cc 
	$(CC) $(CXXFLAGS) -c ./CorrectionFiles/Rochester/RoccoR.cc -o RoccoR.o

XYMETCorrection_withUL17andUL18andUL16.o: ./CorrectionFiles/METXY/XYMETCorrection_withUL17andUL18andUL16.h ./CorrectionFiles/METXY/XYMETCorrection_withUL17andUL18andUL16.cpp
	$(CC) $(CXXFLAGS) -c ./CorrectionFiles/METXY/XYMETCorrection_withUL17andUL18andUL16.cpp -o XYMETCorrection_withUL17andUL18andUL16.o

# Clean all build products
clean:
	-rm -f *~ $(OBJS) core core.*
	-rm -rf ti_files
	-rm -f $(PROGRAM)
	-rm -f *~;

# Full clean including backup
distclean:
	-rm -f *~ $(PROGRAM) $(OBJS)
	-rm -rf ti_files

# Run the program
run: $(PROGRAM) $(OBJS)
	make all
	./$(PROGRAM) 1
