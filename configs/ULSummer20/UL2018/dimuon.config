######## Lepton requirement #######
######## Muon requirement   #######
Muon_ID : "Tight"
MuonPt_cut : 20.0
MuonEta_cut : 2.4
MuonIso_type : "PFIsodbeta04"
MuonIso_cut  : 0.15

######## Elecrtron requirement ######
Elec_ID      : "SCBTight"
ElecPt_cut      : 20.0
ElecEta_cut     : 2.4
ElecIso_type : "PFIsoRho03"
ElecIso_cut  : 0.0821


####### Jet requirement #######
Jet_pt : 30.0
Jet_eta : 2.4
#Jet_ID : "PFLoose"
Jet_ID : "PFTight"
#Jet_btag : "pfCSVV2M"
Jet_btag : "deepCSVL"
BTagSFType : "mujets" # mujets, comb (defalt is comb but BTV recommend mujets for ttbar dilepton analysis)
################## CSVL , CSVM , CSMT #################

PUIDWorkingPoint : "L"
PUIDSFSys : "nom"
ApplyPUID : "true"
PUIDPtThreshold : 50 
####### MET requirement #######
MET_cut : 40.0


####### Veto Muon & Electron Cleaning requirement #######

### case of Muon ###
VetoMuonPt : 20.0
VetoMuonEta : 2.4
VetoMuonId : "Loose"
VetoMuonIso : "PFIsodbeta04"
VetoMuonIsocut : 0.25

### case of Electron ###
VetoElecPt : 20.0
VetoElecEta : 2.4
VetoElecId : "SCBVeto"
VetoElecIdcut : {0.0, 1.0} # Not used...
VetoElecIso : "PFIsoRho03"
VetoElecIsocut : 0.175



