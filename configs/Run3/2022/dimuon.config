PUWeightPath : "LUM/2022_Summer22/puWeights.json.gz"
JERSFPath : "JME/2022_Summer22/jet_jerc.json.gz"
JECPath : "JME/2022_Summer22/jet_jerc.json.gz"
JESName : "Summer22_22Sep2023_V2_MC_L1L2L3Res_AK4PFPuppi"
JERPath : "JME/2022_Summer22/jet_jerc.json.gz"
JMARPath : ""
JetVetoPath : "JME/2022_Summer22/jetvetomaps.json.gz"
