######### Center Of Energy #########
CenOfEn : "13.6TeV"

######### Luminosity #############
#Luminosity : 109525116819.0
Luminosity : 9693000000.0
RunRange : "2023BPix" ### 2016PreVFP , 2016PostAPV 2017 2018 
######## Decay Mode #######
Channel: "dimuon"

######## Total Number of Event for Each Sample ######
UsingTotalEvent : "True"
########### false or true #######

XSecTablesName : "2023BPix.txt"
##TTJetSYs    FSRUp,     FSRDown,   ISRUp,     ISRDown,   TuneUp,   TuneDown, Herwig,   EvtGen,  hdampUp,  hdampDown, GluoneMoveCRTune_erdON, GluoneMoveCRTune , QCDCRTune, erdON  ##########

####### METFilter requirement #######
METFilters : {"Flag_goodVertices", "Flag_globalSuperTightHalo2016Filter", "Flag_HBHENoiseFilter", "Flag_HBHENoiseIsoFilter", "Flag_EcalDeadCellTriggerPrimitiveFilter", "Flag_BadPFMuonFilter", "Flag_BadPFMuonDzFilter", "Flag_eeBadScFilter", "Flag_ecalBadCalibFilter"} # Flag_hfNoisyHitsFilter new filter & optional Flag_BadChargedCandidateFilter is not recommanded...
####### PileUp File #######
PileUpMCFileName : "UL2018/MC_Pileup.root"
PileUpDATAFileName : "UL2018/Offcial_Data.root"

####### Trigger requirement #######
dileptrigger : {"HLT_Mu17_TrkIsoVVL_Mu8_TrkIsoVVL_DZ_Mass3p8"}
singleleptrigger : {"HLT_IsoMu24_v"}


######## Lepton requirement #######
######## Muon requirement   #######
Muon_ID : "Tight"
MuonPt_cut : 20.0
MuonEta_cut : 2.4
MuonIso_type : "PFIsodbeta04"
MuonIso_cut  : 0.15

######## Elecrtron requirement ######
Elec_ID      : "SCBTight"
ElecPt_cut      : 20.0
ElecEta_cut     : 2.4
ElecIso_type : "PFIsoRho03"
ElecIso_cut  : 0.0821


####### Jet requirement #######
Jet_pt : 30.0
Jet_eta : 2.4
Jet_ID : "PuppiTight"
#Jet_btag : "pfCSVV2M"
#Jet_btag : "deepCSVL"
Jet_btag : "UParTAK4L"
BTagSFType : "mujets" # mujets, comb (defalt is comb but BTV recommend mujets for ttbar dilepton analysis)
BTagSFSys : "central"
BTagEffSys : "central"
################## CSVL , CSVM , CSMT #################

PUIDWorkingPoint : "L"
PUIDSFSys : "nom"
ApplyPUID : "false"
PUIDPtThreshold : 50 
####### MET requirement #######
MET_cut : 40.0

####### MET Algoritm #######
METtype : "Puppi" ## PF or Puppi
applyMETXY : "False" ## "False" or "True"

####### Rochester Correction #######
applyRochester : "False"  ## "False" or "True"


####### Veto Muon & Electron Cleaning requirement #######

### case of Muon ###
VetoMuonPt : 20.0
VetoMuonEta : 2.4
VetoMuonId : "Loose"
VetoMuonIso : "PFIsodbeta04"
VetoMuonIsocut : 0.25

### case of Electron ###
VetoElecPt : 20.0
VetoElecEta : 2.4
VetoElecId : "SCBVeto"
VetoElecIdcut : {0.0, 1.0} # Not used...
VetoElecIso : "PFIsoRho03"
VetoElecIsocut : 0.175

### Lepton Scale Factor ###
#TrigSFFile : "TriggerSFDiMuon.root"
#TrigSFFile : "triggerSummary_mumu.root"
TrigSFFile : "TriggerSF_2018_ULv2.root"
TrigSFHist : "h2D_SF_mumu_lepABpt_FullError" ## h2D_SF_mumu_lepABpt_FullError dimuon h2D_SF_ee_lepABpt_FullError dielec,  h2D_SF_emu_lepABpt_FullError muel

### Do JER ??
DoJER : "true"
#DoJER : "false"
### Corrections & SFs with correctionlib ###
PileupSys : "nominal"
L1PreFireSys : "central" ## central ,up,down, none
TrigSFSys : "nominal"
## JSon Path ##
PUWeightPath : "LUM/2023_Summer23BPix/puWeights.json.gz"
JERSFPath : "JME/2023_Summer23BPix/jet_jerc.json.gz"
JECPath : "JME/2023_Summer23BPix/jet_jerc.json.gz"
JESName : "Summer23BPixPrompt23_V3_MC_L1L2L3Res_AK4PFPuppi"
JERPath : "JME/2023_Summer23BPix/jet_jerc.json.gz"
JMARPath : ""
JetVetoPath : "JME/2023_Summer23BPix/jetvetomaps.json.gz"
JetVetoName : "Summer23BPixPrompt23_RunD_V1"
JetVetoKey: "jetvetomap" # "jetvetomap, jetvetomap_hot, jetvetomap_all, jetvetomap_hem1516" 
JetVetoType: "event" # jet/event 
JetIDPath : "JME/2023_Summer23BPix/jetid.json.gz"
JetIDTightName : "AK4PUPPI_Tight"
JetIDTightLepVetoName : "AK4PUPPI_TightLeptonVeto"

#JECName : "Summer23BPixPrompt23_V3_MC_L1L2L3Res_AK4PFPuppi" ## 
JECName : "Summer23BPixPrompt23_V3" ## 
JERName : "Summer23BPixPrompt23_RunD_JRV1_MC_ScaleFactor_AK4PFPuppi" ## JER Sf name 
JERResName : "Summer23BPixPrompt23_RunD_JRV1_MC_PtResolution_AK4PFPuppi" ## Resolution (pt or phi)


MuonSFPath : "MUO/2023_Summer23BPix/muon_Z.json.gz"
MuonIDSFName : "NUM_TightID_DEN_TrackerMuons"
MuonIsoSFName : "NUM_TightPFIso_DEN_TightID"

ElecSFPath : "EGM/2023_Summer23BPix/electron.json.gz"
ElecIDSFName : "Electron-ID-SF"

LepIDSFSys : "nominal"
LepIsoSFSys : "nominal"
LepRecoSFSys : "nominal"
LepTrackSFSys : "nominal" 
